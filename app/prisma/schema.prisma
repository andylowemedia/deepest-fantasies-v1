generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  username     String    @unique
  passwordHash String
  avatar       String?
  bio          String?
  isAdmin      Boolean   @default(false)
  createdAt    DateTime  @default(now())
  comments     Comment[]
  likes        Like[]
}

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  images      Image[]
}

model Image {
  id          String    @id @default(cuid())
  title       String
  description String?
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id])
  tags        String[]
  viewCount   Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  comments    Comment[]
  likes       Like[]
  media       Media[]
}

model Media {
  id          String  @id @default(cuid())
  imageId     String
  image       Image   @relation(fields: [imageId], references: [id], onDelete: Cascade)
  url         String
  mediaType   String  @default("image")
  posterUrl   String?
  caption     String?
  objectPosition String?
  width       Int?
  height      Int?
  order       Int     @default(0)

  @@index([imageId, order])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageId   String
  image     Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Like {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageId String
  image   Image  @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@unique([userId, imageId])
}